---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/marsic/Nav.astro";
import Hero from "@/components/marsic/Hero.astro";
import AIFocus from "@/components/marsic/AIFocus.astro";
import About from "@/components/marsic/About.astro";
import Services from "@/components/marsic/Services.astro";
import Courses from "@/components/marsic/Courses.astro";
import Connect from "@/components/marsic/Connect.astro";
import Footer from "@/components/marsic/Footer.astro";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    mainEntity: {
        "@type": "Person",
        name: "Marko Arsić",
        alternateName: "marsicdev",
        jobTitle: "Independent Software Consultant & AI Advisor",
        description:
            "Independent software consultant with 10+ years of experience. Specializing in AI agents, LLM workflows, software architecture, and helping companies transform to AI-first development.",
        url: "https://marsic.dev",
        sameAs: [
            "https://linkedin.com/in/marsicdev",
            "https://github.com/marsicdev",
            "https://x.com/mArsic",
            "https://instagram.com/marsic.dev",
        ],
        worksFor: {
            "@type": "Organization",
            name: "hypetech.io",
            url: "https://hypetech.io",
        },
        knowsAbout: [
            "AI Agents",
            "LLM Workflows",
            "RAG Applications",
            "AI-Assisted Development",
            "Software Architecture",
            "Full-Stack Development",
            "System Design",
            "Technical Consulting",
            "React",
            "TypeScript",
            "Node.js",
            "Python",
        ],
        address: {
            "@type": "PostalAddress",
            addressLocality: "Belgrade",
            addressCountry: "RS",
        },
    },
};
---

<Layout
  title="Marko Arsić | Independent Software & AI Consultant"
  description="Marko Arsić — Independent software consultant specializing in AI agents, LLM workflows, software architecture, and full-stack engineering. Founder of hypetech.io. 10+ years of experience."
  structuredData={personSchema}
  snapScroll
>
  <Nav />

  <main class="snap-container">
    <Hero />
    <AIFocus />
    <About />
    <Services />
    <Courses />
    <Connect />
    <Footer />
  </main>
</Layout>

<style>
  /* Mobile snap scroll fix */
  @media (max-width: 767px) {
    main.snap-container {
      scroll-snap-type: y proximity;
    }
    main.snap-container :global(.snap-section) {
      min-height: auto;
      padding-top: 5rem;
      padding-bottom: 4rem;
    }
    main.snap-container :global(.snap-section.hero-section) {
      min-height: 100vh;
      min-height: 100dvh;
      padding-top: 0;
      padding-bottom: 0;
    }
  }
</style>

<script>
  // Scroll-triggered fade-in
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    }
  );

  document.querySelectorAll(".fade-in-up").forEach((el) => {
    observer.observe(el);
  });
</script>
