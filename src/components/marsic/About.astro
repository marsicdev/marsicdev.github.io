---
const techStack = [
    "TypeScript",
    "Python",
    "React",
    "React Native",
    "Node.js",
    "Next.js",
    "LangChain",
    "Claude API",
    "OpenAI",
    "PostgreSQL",
    "Supabase",
    "AWS",
    "Docker",
    "GraphQL",
    "REST",
    "System Design",
];
---

<section id="about" class="snap-section items-center px-6 md:px-12 bg-gray-50 dark:bg-[#030303] relative overflow-hidden border-y border-black/10 dark:border-white/5">
  <div class="geo-triangle triangle-md top-[12%] right-[10%] animate-float-slow"></div>
  <div class="geo-square w-12 h-12 bottom-[18%] left-[8%] animate-rotate-float"></div>

  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center relative z-10">
    <div class="space-y-8">
      <div>
        <span class="text-sm font-medium text-gray-500 dark:text-gray-500 uppercase tracking-[0.25em]">About</span>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-extralight mt-6 tracking-tight">
          Your <span class="font-black accent-gradient">technical partner</span>
        </h2>
      </div>
      <div class="space-y-7 text-gray-600 dark:text-gray-400 text-[19px] leading-[1.8]">
        <p>
          With <span class="accent-gradient font-medium">10+ years in software engineering</span>, I've worked across the entire stack — from mobile apps to distributed backends, from startup MVPs to enterprise-scale platforms. Through <a href="https://hypetech.io" class="accent-gradient font-medium hover:opacity-80 transition-opacity">hypetech.io</a> — the studio I founded — I deliver end-to-end engineering and AI solutions to companies worldwide.
        </p>
        <p>
          Right now, my primary focus is helping companies navigate the <span class="accent-gradient font-medium">AI transformation</span>. Most teams are barely scratching the surface. I help them go from basic AI usage to production-grade agents, workflows, and LLM integrations that actually move the needle.
        </p>
      </div>
    </div>

    <!-- Stats Card -->
    <div class="fade-in-up fade-in-up-delay-2">
      <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 p-8 md:p-10 space-y-6">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <div class="text-4xl md:text-5xl font-extralight accent-gradient">10+</div>
            <div class="text-sm text-gray-500 dark:text-gray-500 mt-2 uppercase tracking-wider">Years Experience</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-extralight accent-gradient">50+</div>
            <div class="text-sm text-gray-500 dark:text-gray-500 mt-2 uppercase tracking-wider">Projects Delivered</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-extralight text-gray-950 dark:text-white">3</div>
            <div class="text-sm text-gray-500 dark:text-gray-500 mt-2 uppercase tracking-wider">Languages Spoken</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-extralight text-gray-950 dark:text-white">&infin;</div>
            <div class="text-sm text-gray-500 dark:text-gray-500 mt-2 uppercase tracking-wider">Cups of Coffee</div>
          </div>
        </div>
        <div class="pt-4 border-t border-gray-200 dark:border-white/10">
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="px-3 py-1 text-xs font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-full">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .accent-gradient {
    background: linear-gradient(135deg, #8b5cf6, #ec4899, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
