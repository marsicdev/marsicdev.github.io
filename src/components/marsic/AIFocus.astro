---
// AI Focus sections: Header, Three Pillars, and Transformation CTA
---

<!-- Section: AI Focus — Header -->
<section id="ai" class="snap-section items-center text-center px-6 md:px-12 bg-gray-950 dark:bg-[#050505] text-white relative overflow-hidden border-y border-white/10">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[10%] left-[5%] w-2 h-2 rounded-full bg-white/20 animate-pulse-slow"></div>
    <div class="absolute top-[20%] right-[12%] w-1.5 h-1.5 rounded-full bg-white/15 animate-pulse-slow" style="animation-delay: 1s"></div>
    <div class="shape w-[500px] h-[500px] -top-64 -right-64 animate-spin-slow opacity-[0.06] rounded-full border-white/20"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10 fade-in-up">
    <span class="inline-block py-2.5 px-5 rounded-full accent-gradient-bg text-white text-xs font-medium tracking-[0.2em] uppercase mb-8">
      Primary Focus
    </span>
    <h2 class="text-5xl md:text-7xl lg:text-8xl font-extralight leading-[1.05] tracking-tight">
      Building the future with
      <br />
      <span class="font-black accent-gradient">AI agents</span> <span class="font-bold">& workflows</span>
    </h2>
    <p class="text-white/50 text-xl md:text-2xl mt-10 leading-[1.7] max-w-2xl mx-auto">
      I help companies move beyond basic ChatGPT usage into production-grade AI systems — agents that reason, workflows that automate, and LLM integrations that deliver real business value.
    </p>
  </div>
</section>

<!-- Section: AI Focus — Three Pillars -->
<section class="snap-section items-center px-6 md:px-12 bg-gray-950 dark:bg-[#050505] text-white relative overflow-hidden border-b border-white/10">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[60%] left-[15%] w-1 h-1 rounded-full bg-white/25 animate-pulse-slow" style="animation-delay: 2s"></div>
    <div class="absolute bottom-[25%] right-[20%] w-2 h-2 rounded-full bg-white/15 animate-pulse-slow" style="animation-delay: 0.5s"></div>
    <div class="absolute top-[15%] left-[8%] w-[200px] h-px bg-gradient-to-r from-white/10 via-white/5 to-transparent rotate-[25deg] animate-pulse-slow"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10 w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
      <!-- Pillar 1: AI Agents -->
      <div class="fade-in-up fade-in-up-delay-1 group relative p-8 md:p-10 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] accent-glow transition-all duration-500">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-violet-500/30 via-50% to-transparent"></div>
        <div class="w-12 h-12 flex items-center justify-center rounded-lg mb-6 transition-colors" style="background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(236,72,153,0.15))">
          <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">AI Agents</h3>
        <p class="text-white/40 text-base leading-relaxed mb-6">
          Autonomous agents that reason, plan, and execute complex tasks. From code assistants to customer support — agents that actually work in production.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">LangChain</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">CrewAI</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Claude Agent SDK</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">OpenAI Agents</span>
        </div>
      </div>

      <!-- Pillar 2: AI Workflows -->
      <div class="fade-in-up fade-in-up-delay-2 group relative p-8 md:p-10 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] accent-glow transition-all duration-500">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-violet-500/30 via-50% to-transparent"></div>
        <div class="w-12 h-12 flex items-center justify-center rounded-lg mb-6 transition-colors" style="background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(236,72,153,0.15))">
          <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">AI Workflows</h3>
        <p class="text-white/40 text-base leading-relaxed mb-6">
          End-to-end automation pipelines that connect LLMs to your business processes. RAG systems, document processing, intelligent routing, and decision engines.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">RAG Pipelines</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Vector DBs</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">n8n</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Custom Pipelines</span>
        </div>
      </div>

      <!-- Pillar 3: LLM Integration -->
      <div class="fade-in-up fade-in-up-delay-3 group relative p-8 md:p-10 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] accent-glow transition-all duration-500">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-violet-500/30 via-50% to-transparent"></div>
        <div class="w-12 h-12 flex items-center justify-center rounded-lg mb-6 transition-colors" style="background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(236,72,153,0.15))">
          <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">LLM Integration</h3>
        <p class="text-white/40 text-base leading-relaxed mb-6">
          Embedding AI into existing products and workflows. Prompt engineering, model selection, fine-tuning strategies, and production-ready API integrations.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Claude API</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">OpenAI</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Gemini</span>
          <span class="px-2.5 py-1 text-[11px] font-medium text-white/50 border border-white/10 rounded-full">Local Models</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section: AI Transformation CTA -->
<section class="snap-section items-center px-6 md:px-12 bg-gray-950 dark:bg-[#050505] text-white relative overflow-hidden border-b border-white/10">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[40%] left-[40%] w-1.5 h-1.5 rounded-full bg-white/10 animate-pulse-slow" style="animation-delay: 1.5s"></div>
    <div class="absolute bottom-[15%] left-[60%] w-1 h-1 rounded-full bg-white/20 animate-pulse-slow" style="animation-delay: 3s"></div>
    <div class="shape w-[400px] h-[400px] -bottom-48 -left-48 animate-spin-reverse opacity-[0.04] rounded-full border-white/15"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10 w-full">
    <div class="fade-in-up fade-in-up-delay-4 relative border border-white/10 bg-white/[0.02] p-8 md:p-12 lg:p-16">
      <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-3xl md:text-4xl font-extralight mb-6 tracking-tight">
            Transform your team to <span class="font-black accent-gradient">AI-first</span> development
          </h3>
          <p class="text-white/40 text-lg leading-[1.75]">
            Most teams are using AI at 10% of its potential. I help engineering organizations adopt AI-assisted development workflows that fundamentally change how they build software — from code generation and review to testing and deployment.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border border-violet-500/30 text-xs text-violet-400 font-medium mt-0.5">1</div>
            <div>
              <div class="font-medium text-white/90">Assess & Strategize</div>
              <div class="text-sm text-white/40 mt-1">Audit current workflows, identify high-impact AI opportunities</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border border-violet-500/30 text-xs text-violet-400 font-medium mt-0.5">2</div>
            <div>
              <div class="font-medium text-white/90">Implement & Train</div>
              <div class="text-sm text-white/40 mt-1">Set up AI tooling, build custom agents, hands-on team workshops</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border border-violet-500/30 text-xs text-violet-400 font-medium mt-0.5">3</div>
            <div>
              <div class="font-medium text-white/90">Scale & Optimize</div>
              <div class="text-sm text-white/40 mt-1">Measure velocity gains, refine workflows, expand across the org</div>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-10">
        <a
          href="https://cal.com/marsicdev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 accent-gradient-bg text-white hover:opacity-90 px-10 py-5 rounded-lg text-lg font-medium transition-all"
        >
          Book a discovery call
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .accent-gradient {
    background: linear-gradient(135deg, #8b5cf6, #ec4899, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .accent-gradient-bg {
    background: linear-gradient(135deg, #8b5cf6, #ec4899, #f59e0b);
  }

  .accent-glow:hover {
    border-color: rgba(139, 92, 246, 0.4);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.08), 0 0 40px rgba(236, 72, 153, 0.05);
  }

  :is(.dark .accent-glow:hover) {
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.12), 0 0 40px rgba(236, 72, 153, 0.08);
  }
</style>
