---
// Connect / Work with me section - bento grid of social links
---

<section id="connect" class="snap-section items-center px-6 md:px-12 relative overflow-hidden">
  <div class="geo-triangle triangle-lg top-[12%] left-[8%] animate-rotate-float"></div>
  <div class="geo-halfcircle geo-halfcircle-md bottom-[20%] left-[12%] animate-rotate-float-reverse rotate-180"></div>
  <div class="shape w-75 h-75 -top-32 -right-32 animate-spin-slow opacity-15 rounded-full"></div>

  <div class="max-w-5xl mx-auto relative z-10 w-full">
    <div class="text-center mb-16">
      <h2 class="text-5xl md:text-6xl font-extralight tracking-tighter">
        Let's <span class="font-black accent-gradient">work together</span>
      </h2>
      <p class="text-gray-600 dark:text-gray-400 text-xl font-light mt-6 max-w-xl mx-auto">
        Have a project, need consulting, or want to explore AI for your team?
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Email — large, spans full width -->
      <a
        href="mailto:marko@hypetech.io"
        class="bento-card group md:col-span-2 p-8 md:p-10 border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm accent-glow transition-all duration-300"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-gray-400 dark:text-gray-500 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <div>
              <div class="text-xl font-medium text-gray-950 dark:text-white group-hover:translate-x-1 transition-transform duration-300">Email</div>
              <div class="text-base text-gray-500 dark:text-gray-500 mt-0.5">marko@hypetech.io</div>
            </div>
          </div>
          <svg class="w-6 h-6 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 dark:group-hover:text-gray-400 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </div>
      </a>

      <!-- Schedule a Call -->
      <a
        href="https://cal.com/marsicdev"
        target="_blank"
        rel="noopener noreferrer"
        class="bento-card group p-8 md:p-10 border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm accent-glow transition-all duration-300"
      >
        <div class="flex flex-col justify-between h-full gap-6">
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-gray-400 dark:text-gray-500 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            <div class="text-xl font-medium text-gray-950 dark:text-white group-hover:translate-x-1 transition-transform duration-300">Schedule a Call</div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-base text-gray-500 dark:text-gray-500">Let's discuss your project</span>
            <svg class="w-6 h-6 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 dark:group-hover:text-gray-400 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
            </svg>
          </div>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://linkedin.com/in/marsicdev"
        target="_blank"
        rel="noopener noreferrer"
        class="bento-card group p-8 md:p-10 border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm accent-glow transition-all duration-300"
      >
        <div class="flex flex-col justify-between h-full gap-6">
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-gray-400 dark:text-gray-500 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            <div class="text-xl font-medium text-gray-950 dark:text-white group-hover:translate-x-1 transition-transform duration-300">LinkedIn</div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-base text-gray-500 dark:text-gray-500">Professional profile</span>
            <svg class="w-6 h-6 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 dark:group-hover:text-gray-400 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
            </svg>
          </div>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/marsicdev"
        target="_blank"
        rel="noopener noreferrer"
        class="bento-card group p-8 md:p-10 border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm accent-glow transition-all duration-300"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-gray-400 dark:text-gray-500 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
            </svg>
            <div>
              <div class="text-xl font-medium text-gray-950 dark:text-white group-hover:translate-x-1 transition-transform duration-300">GitHub</div>
              <div class="text-base text-gray-500 dark:text-gray-500 mt-0.5">Open source & projects</div>
            </div>
          </div>
          <svg class="w-6 h-6 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 dark:group-hover:text-gray-400 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </div>
      </a>

      <!-- X / Twitter -->
      <a
        href="https://x.com/mArsic"
        target="_blank"
        rel="noopener noreferrer"
        class="bento-card group p-8 md:p-10 border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm accent-glow transition-all duration-300"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-gray-400 dark:text-gray-500 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.261 48.261 0 0 0 5.048-.37c1.588-.232 2.714-1.627 2.714-3.228V6.741c0-1.602-1.126-2.995-2.714-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
            <div>
              <div class="text-xl font-medium text-gray-950 dark:text-white group-hover:translate-x-1 transition-transform duration-300">X / Twitter</div>
              <div class="text-base text-gray-500 dark:text-gray-500 mt-0.5">Thoughts & updates</div>
            </div>
          </div>
          <svg class="w-6 h-6 text-gray-300 dark:text-gray-700 group-hover:text-gray-500 dark:group-hover:text-gray-400 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </div>
      </a>
    </div>

    <p class="mt-12 text-center text-base text-gray-500 dark:text-gray-600">
      Belgrade, Serbia · Working globally
    </p>
  </div>
</section>

<style>
  .accent-gradient {
    background: linear-gradient(135deg, #8b5cf6, #ec4899, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .accent-glow:hover {
    border-color: rgba(139, 92, 246, 0.4);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.08), 0 0 40px rgba(236, 72, 153, 0.05);
  }

  :is(.dark .accent-glow:hover) {
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.12), 0 0 40px rgba(236, 72, 153, 0.08);
  }

  .bento-card {
    transform: translateY(0);
  }

  .bento-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  :is(.dark .bento-card:hover) {
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.05);
  }
</style>
